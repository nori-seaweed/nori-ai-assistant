# LINE
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# Gemini (Claude応答 / 歌詞生成 / Whisper代替)
GEMINI_API_KEY=your_gemini_api_key

# Notion
NOTION_API_KEY=your_notion_api_key
NOTION_DATABASE_ID=your_notion_database_id

# YouTube Data API v3 (scripts/get_youtube_token.py で取得)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token
YOUTUBE_PRIVACY=public  # private | unlisted | public

# 一時ファイル保存先（省略可。デフォルトは /tmp/...）
JOB_DB_PATH=/tmp/nori_jobs.db
AUDIO_DIR=/tmp/nori_audio
THUMB_DIR=/tmp/nori_thumbs
VIDEO_DIR=/tmp/nori_videos
DEFAULT_COVER_PATH=
